{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Perch Developer Platform",
  "api": {
    "examples": {
      "prefill": true
    }
  },
  "colors": {
    "primary": "#327766",
    "light": "#4A9B8E",
    "dark": "#225544"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Get Started",
        "groups": [
          {
            "group": "Welcome",
            "pages": [
              "index",
              "getting-started/integration-options",
              "getting-started/terms-of-use"
            ]
          },
          {
            "group": "Core API",
            "pages": [
              "getting-started/overview",
              "core-concepts/leads-and-plans",
              "getting-started/authentication",
              "getting-started/postman-setup",
              "getting-started/errors-and-response-codes",
              "getting-started/rate-limits",
              "getting-started/pagination",
              "api-reference/submitting-and-tracking-leads"
            ]
          },
          {
            "group": "Lending API",
            "pages": [
              "lending-services/overview",
              "lending-services/authentication",
              "lending-services/postman-setup",
              "lending-services/errors-and-response-codes",
              "lending-services/rate-limits",
              "lending-services/glossary"
            ]
          },
          {
            "group": "Embeds",
            "pages": [
              "embeds/overview",
              "embeds/implementation",
              "embeds/customization",
              "embeds/authenticated-embeds",
              "embeds/lead-management"
            ]
          }
        ]
      },
      {
        "tab": "Partner API",
        "groups": [
          {
            "group": "Partner API Reference",
            "openapi": {
              "source": "https://perch-api-docs.s3.ca-central-1.amazonaws.com/perch-partner.spec.json",
              "directory": "partner-api"
            }
          }
        ]
      },
      {
        "tab": "Realtor API",
        "groups": [
          {
            "group": "Realtor API Reference",
            "openapi": {
              "source": "https://perch-api-docs.s3.ca-central-1.amazonaws.com/perch-realtor.spec.json",
              "directory": "realtor-api"
            }
          }
        ]
      }
    ],
    "global": {}

  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Contact Support",
        "href": "mailto:support@myperch.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Client Portal",
      "href": "https://app.myperch.io"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/perchcanada/",
      "facebook": "https://www.facebook.com/PerchCanada/"
    }
  }
}